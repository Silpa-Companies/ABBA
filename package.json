{
  "name": "@abba/root",
  "version": "0.0.0",
  "private": true,
  "description": "ABBA monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --filter='!@abba/docs' run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
